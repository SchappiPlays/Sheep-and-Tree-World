{
  "name": "sheep-and-tree-world",
  "version": "1.5.0",
  "main": "main.js",
  "author": "Lucas",
  "description": "Sheep and Tree World",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.lucas.sheepandtreeworld",
    "productName": "Sheep and Tree World",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games",
      "icon": "icon.icns"
    },
    "win": {
      "icon": "icon.ico"
    },
    "files": [
      "main.js",
      "index.html",
      "*.js",
      "*.png",
      "*.mp3",
      "!node_modules"
    ]
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
